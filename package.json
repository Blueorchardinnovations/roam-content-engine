{
  "name": "roam-content-engine_dev",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "db:health": "tsx src/db/health-check.ts",
    "dev": "tsx watch src/api/server.ts",
    "start": "tsx src/api/server.ts",
    "worker:dev": "tsx watch src/worker/server.ts",
    "worker:start": "tsx src/worker/server.ts",
    "worker:publish:dev": "tsx watch src/worker/publish-server.ts",
    "worker:publish": "tsx src/worker/publish-server.ts",
    "publish-worker:dev": "tsx watch src/worker/publish-server.ts",
    "publish-worker:start": "tsx src/worker/publish-server.ts",
    "test": "vitest run --maxWorkers=1",
    "test:api": "vitest run tests/integration/api",
    "test:worker": "vitest run --maxWorkers=1 tests/unit/workers tests/integration/workers",
    "test:ai": "vitest run --maxWorkers=1 tests/unit/ai tests/integration/ai tests/unit/workers/deterministic-transcript-processor-ai.test.ts",
    "test:publication": "vitest run tests/unit/publications tests/integration/publications tests/unit/workers/deterministic-transcript-processor-publication.test.ts",
    "test:html": "vitest run tests/unit/publications/html-composer.test.ts tests/unit/publications/html-schemas.test.ts tests/unit/workers/deterministic-transcript-processor-publication.test.ts tests/integration/publications/publication-worker.int.test.ts",
    "test:rendering": "vitest run tests/unit/rendering",
    "test:publish-engine": "vitest run tests/unit/infrastructure/publish-engine tests/integration/publish-engine",
    "test:publish-jobs": "vitest run --maxWorkers=1 tests/unit/publish-jobs tests/unit/workers/publish-*.test.ts tests/integration/repositories/publish-job*.int.test.ts tests/integration/api/publish-jobs*.int.test.ts tests/integration/workers/publish-worker.int.test.ts",
    "test:packaging": "vitest run tests/unit/publication-packaging tests/integration/publications/styled-publication-package.int.test.ts",
    "test:themes": "vitest run tests/unit/themes",
    "test:unit": "vitest run tests/platform tests/domain",
    "test:integration": "vitest run --maxWorkers=1 tests/integration",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@fastify/sensible": "^6.0.4",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "openai": "^6.48.0",
    "pg": "^8.22.0",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
